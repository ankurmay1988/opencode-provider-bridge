{
  "name": "opencode-provider-bridge",
  "displayName": "Opencode Provider Bridge",
  "description": "Brings all OpenCode providers and models into VS Code Copilot's model picker",
  "version": "0.5.0",
  "publisher": "ankurmathur",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ankurmay1988/opencode-provider-bridge"
  },
  "bugs": {
    "url": "https://github.com/ankurmay1988/opencode-provider-bridge/issues"
  },
  "type": "module",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "opencode",
    "copilot",
    "byok",
    "llm",
    "provider",
    "ai"
  ],
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "pricing": "Free",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.cjs",
  "contributes": {
    "configuration": {
      "title": "OpenCode Provider Bridge",
      "properties": {
        "opencode-provider-bridge.logLevel": {
          "type": "string",
          "default": "info",
          "enum": [
            "error",
            "warn",
            "info",
            "debug"
          ],
          "enumDescriptions": [
            "Only errors",
            "Errors and warnings",
            "Errors, warnings, and info messages",
            "Everything including verbose debug messages"
          ],
          "description": "Log verbosity level for the OpenCode Bridge output panel."
        }
      }
    },
    "languageModelChatProviders": [
      {
        "vendor": "opencode-provider-bridge",
        "displayName": "OpenCode Providers",
        "configuration": {
          "properties": {
            "apiKey": {
              "type": "string",
              "secret": true,
              "description": "API key for OpenCode providers",
              "defaultSnippets": [
                {
                  "body": "sk-..."
                }
              ]
            }
          }
        }
      }
    ],
    "commands": [
      {
        "command": "opencode-provider-bridge.refreshModels",
        "title": "OpenCode Bridge: Refresh Model List"
      },
      {
        "command": "opencode-provider-bridge.showStatus",
        "title": "OpenCode Bridge: Show Status"
      },
      {
        "command": "opencode-provider-bridge.setApiKey",
        "title": "OpenCode Bridge: Set API Key for a Provider"
      },
      {
        "command": "opencode-provider-bridge.removeProvider",
        "title": "OpenCode Bridge: Remove Provider Key"
      }
    ]
  },
  "scripts": {
    "clean": "rimraf dist",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "watch:esbuild": "node esbuild.js --watch",
    "watch": "npm run clean && npm-run-all -p watch:*",
    "vscode:prepublish": "npm run package",
    "compile": "npm run clean && npm run check-types && npm run lint && node esbuild.js",
    "package": "npm run clean && npm run check-types && npm run lint && node esbuild.js --production"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.77",
    "@ai-sdk/google": "^3.0.73",
    "@ai-sdk/openai-compatible": "^2.0.47",
    "@opencode-ai/sdk": "^1.14.0",
    "ai": "^6.0.180"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.19",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^2.10.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "rimraf": "^5.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
